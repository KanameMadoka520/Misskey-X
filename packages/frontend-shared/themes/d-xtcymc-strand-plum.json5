// Strand Plum — 取自 Taffy 系列 v236「Strand」AI 聊天紫雾配色
// 黑曜底 + 紫雾主色 + 巧克力棕辅色，沉静夜色界面
{
	id: 'a3c8b614-2e5d-4a93-bc40-7c1a9d3e5f08',

	name: 'Xtcymc Strand Plum Dark',
	author: 'KanameMadoka520',
	desc: '黑曜紫雾：obsidian 底 + 紫色主色 + 巧克力棕辅色 + 薄荷成功，深夜阅读体感',

	base: 'dark',

	props: {
		accent: '#A78BFA',
		accentedBg: ':alpha<0.16<@accent',
		focus: ':alpha<0.30<@accent',
		bg: '#06080C',
		fg: '#D4D2DE',
		fgHighlighted: '#F4F1FB',
		fgOnAccent: '#1B1233',
		fgOnWhite: '@accent',
		divider: 'rgba(167, 139, 250, 0.14)',
		panel: '#0F1018',
		panelHighlight: '#171825',
		panelHeaderBg: '#11121C',
		header: ':alpha<0.78<@panel',
		navBg: '#08090E',
		navFg: '#C8C5D8',
		navActive: '@accent',
		navIndicator: '#F8A26A',
		pageHeaderBg: '@bg',
		link: '#C4B5FD',
		hashtag: '#F8A26A',
		mention: '@accent',
		mentionMe: '#FB7AB5',
		renote: '#5EEAD4',
		shadow: 'rgba(0, 0, 0, 0.55)',
		infoBg: '#1B1936',
		infoFg: '#C4B5FD',
		infoWarnBg: '#3A2611',
		infoWarnFg: '#F8A26A',
		folderHeaderBg: 'rgba(167, 139, 250, 0.06)',
		folderHeaderHoverBg: 'rgba(167, 139, 250, 0.12)',
		buttonBg: ':lighten<5<@panel',
		buttonHoverBg: ':lighten<10<@panel',
		buttonGradateA: '@accent',
		buttonGradateB: '#F8A26A',
		switchOnBg: '@accentedBg',
		switchOnFg: '@accent',
		inputBorder: 'rgba(167, 139, 250, 0.16)',
		inputBorderHover: 'rgba(167, 139, 250, 0.32)',
		badge: '#F8A26A',
		success: '#5EEAD4',
		error: '#FB7AB5',
		warn: '#F8A26A',
		codeString: '#F8A26A',
		codeNumber: '#5EEAD4',
		codeBoolean: '#C4B5FD',
		deckBg: '#04050A',
		htmlThemeColor: '@bg',
	},

	codeHighlighter: {
		base: 'rose-pine-moon',
	},
}
