// Veer Citrine — 取自 Taffy 系列 v239「Veer」AI 搜索深空配色
// 极深蓝底 + 青色主色 + 柠檬黄强调 + 玫瑰提及
{
	id: 'f47c1d2a-6b85-4f7c-9d3b-4e8a2c1b6d05',

	name: 'Xtcymc Veer Citrine Dark',
	author: 'KanameMadoka520',
	desc: '深空蓝青：深海蓝底 + 青色主色 + 柠檬黄点缀 + 玫瑰提及，明亮可读',

	base: 'dark',

	props: {
		accent: '#38BDF8',
		accentedBg: ':alpha<0.15<@accent',
		focus: ':alpha<0.30<@accent',
		bg: '#060B14',
		fg: '#D7E4F4',
		fgHighlighted: '#F4F8FF',
		fgOnAccent: '#04111B',
		fgOnWhite: '@accent',
		divider: 'rgba(120, 168, 220, 0.16)',
		panel: '#0D1626',
		panelHighlight: '#15203A',
		panelHeaderBg: '#0F1929',
		header: ':alpha<0.78<@panel',
		navBg: '#070D17',
		navFg: '#C7D6EA',
		navActive: '@accent',
		navIndicator: '#F1C40F',
		pageHeaderBg: '@bg',
		link: '#7DD3FC',
		hashtag: '#F1C40F',
		mention: '#F472B6',
		mentionMe: '#FB7185',
		renote: '#34D399',
		shadow: 'rgba(0, 0, 0, 0.55)',
		infoBg: '#142E48',
		infoFg: '#A8D4F4',
		infoWarnBg: '#3A2F15',
		infoWarnFg: '#F1C861',
		folderHeaderBg: 'rgba(120, 168, 220, 0.06)',
		folderHeaderHoverBg: 'rgba(120, 168, 220, 0.12)',
		buttonBg: ':lighten<5<@panel',
		buttonHoverBg: ':lighten<10<@panel',
		buttonGradateA: '@accent',
		buttonGradateB: '#7DD3FC',
		switchOnBg: '@accentedBg',
		switchOnFg: '@accent',
		inputBorder: 'rgba(120, 168, 220, 0.18)',
		inputBorderHover: 'rgba(120, 168, 220, 0.34)',
		badge: '#F1C40F',
		success: '#34D399',
		error: '#FB7185',
		warn: '#F1C40F',
		codeString: '#F1C40F',
		codeNumber: '#34D399',
		codeBoolean: '#F472B6',
		deckBg: '#04090F',
		htmlThemeColor: '@bg',
	},

	codeHighlighter: {
		base: 'tokyo-night',
	},
}
