// Atlas Editorial — 取自 Taffy 系列 v240「Atlas」编辑乳白册页配色
// 纸张感乳白底 + 牛血红 accent + 金箔次色，区别于咖啡褐 l-coffee 与杏橙 l-apricot
{
	id: 'd2f1e1b4-7c9d-4f0e-9b21-2a5c0e8b7a01',

	name: 'Xtcymc Atlas Editorial Light',
	author: 'KanameMadoka520',
	desc: '编辑乳白页：纸张底色 + 牛血红主色 + 金箔点缀，向 Taffy 系列 v240 致敬',

	base: 'light',

	props: {
		accent: '#7A1717',
		accentedBg: ':alpha<0.10<@accent',
		focus: ':alpha<0.30<@accent',
		bg: '#F5EFE4',
		fg: '#2A1F12',
		fgHighlighted: '#0E0A06',
		fgOnAccent: '#FBF6EC',
		fgOnWhite: '@accent',
		divider: 'rgba(14, 10, 6, 0.10)',
		panel: '#FBF6EC',
		panelHighlight: '#F0E9DC',
		panelHeaderBg: '#F8F2E5',
		header: ':alpha<0.80<@panel',
		navBg: '#FBF6EC',
		navFg: '#3B2E1D',
		navActive: '@accent',
		navIndicator: '#9C6B17',
		pageHeaderBg: '@bg',
		link: '#1F4E66',
		hashtag: '#9C6B17',
		mention: '@accent',
		mentionMe: '#8F2D2D',
		renote: '#6B5A28',
		shadow: 'rgba(14, 10, 6, 0.08)',
		infoBg: '#EFE6D2',
		infoFg: '#6E5826',
		infoWarnBg: '#F4DCC7',
		infoWarnFg: '#7A3B11',
		folderHeaderBg: 'rgba(14, 10, 6, 0.04)',
		folderHeaderHoverBg: 'rgba(14, 10, 6, 0.08)',
		buttonBg: ':darken<4<@panel',
		buttonHoverBg: ':darken<8<@panel',
		buttonGradateA: '@accent',
		buttonGradateB: '#9C6B17',
		inputBorder: 'rgba(14, 10, 6, 0.18)',
		inputBorderHover: 'rgba(14, 10, 6, 0.32)',
		badge: '#9C6B17',
		success: '#3D6C2A',
		error: '#9B2222',
		warn: '#A77A1B',
		codeString: '#7A1717',
		codeNumber: '#1F4E66',
		codeBoolean: '#9C6B17',
		deckBg: ':darken<2<@bg',
		htmlThemeColor: '@bg',
	},

	codeHighlighter: {
		base: 'rose-pine-dawn',
	},
}
