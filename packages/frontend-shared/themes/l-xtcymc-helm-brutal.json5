// Helm Brutal — 取自 Taffy 系列 v238「Helm」新粗野浏览器配色
// 暖米黄底 + 深酒红 accent + 卡其，硬朗对比的浅色主题
{
	id: 'b9e44a73-1d6a-4d4b-8c0f-3a7b2c5e9f12',

	name: 'Xtcymc Helm Brutal Light',
	author: 'KanameMadoka520',
	desc: '新粗野浅色：暖米黄底 + 深酒红主色 + 卡其辅色，硬朗对比鲜明',

	base: 'light',

	props: {
		accent: '#7E2A56',
		accentedBg: ':alpha<0.12<@accent',
		focus: ':alpha<0.30<@accent',
		bg: '#FAF8F5',
		fg: '#2B252B',
		fgHighlighted: '#120E11',
		fgOnAccent: '#FFF6FB',
		fgOnWhite: '@accent',
		divider: 'rgba(43, 37, 43, 0.14)',
		panel: '#FFFFFF',
		panelHighlight: '#F2EEE9',
		panelHeaderBg: '#F6F1EA',
		header: ':alpha<0.80<@panel',
		navBg: '#F2EBE0',
		navFg: '#2B252B',
		navActive: '@accent',
		navIndicator: '@accent',
		pageHeaderBg: '@bg',
		link: '#1F5E6B',
		hashtag: '#B05B14',
		mention: '@accent',
		mentionMe: '#9B1E3A',
		renote: '#36766E',
		shadow: 'rgba(20, 16, 20, 0.10)',
		infoBg: '#E7F0EE',
		infoFg: '#2F5F58',
		infoWarnBg: '#F3E1D0',
		infoWarnFg: '#8B4A11',
		folderHeaderBg: 'rgba(20, 16, 20, 0.05)',
		folderHeaderHoverBg: 'rgba(20, 16, 20, 0.10)',
		buttonBg: ':darken<6<@panel',
		buttonHoverBg: ':darken<11<@panel',
		buttonGradateA: '@accent',
		buttonGradateB: '#B05B14',
		inputBorder: 'rgba(20, 16, 20, 0.20)',
		inputBorderHover: 'rgba(20, 16, 20, 0.40)',
		badge: '#B05B14',
		success: '#36766E',
		error: '#A72A2A',
		warn: '#B98414',
		codeString: '#B05B14',
		codeNumber: '#1F5E6B',
		codeBoolean: '#7E2A56',
		deckBg: ':darken<3<@bg',
		htmlThemeColor: '@bg',
	},

	codeHighlighter: {
		base: 'catppuccin-latte',
	},
}
